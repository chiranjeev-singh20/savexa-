# AidSense Environment Variables
# Copy this file to .env and fill in your actual keys.

# Optional: Add your Anthropic API key here to enable Claude AI.
# If left blank, the app will gracefully fall back to its offline knowledge base.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Django configuration
DJANGO_SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
